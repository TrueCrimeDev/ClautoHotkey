# harness.env.example — copy to harness.env and edit, then run ./setup.sh
# harness.env is gitignored; never commit your real values.

# --- Interpreter ---
# Windows path to your AutoHotkey v2 binary. setup.sh derives the WSL path.
AHK_BIN_WIN="C:\\Program Files\\AutoHotkey\\v2\\AutoHotkey64.exe"
# 1 only if your build supports `check /Diag=json` (the +Console fork). Stock AHK: leave 0.
AHK_DIAG_JSON=0

# --- Project ---
PROJECT_DIR="/mnt/c/path/to/your/project"   # hooks mostly use $CLAUDE_PROJECT_DIR; used for rendering
MAIN_SCRIPT="main.ahk"                       # entry script re-validated when a dependency is edited
DEPENDENCY_SCRIPTS=""                         # comma-sep extra files that trigger a main-script recheck
NO_RUNTIME_CHECK=""                           # comma-sep persistent scripts to skip the runtime probe
NO_AUTO_RELOAD=""                             # comma-sep library modules to never auto-restart
RUNTIME_PROBE=1                               # 1 = briefly run standalone scripts to catch runtime errors; 0 = syntax-check only
DEMO_DIR="C:\\path\\to\\your\\project\\Demo"  # where demo scripts are saved

# --- Git identity guard (opt-in; OFF by default) ---
GIT_GUARD_ENABLED=0
GIT_ALLOWED_IDENTITY=""
GIT_BLOCKLIST=""                              # comma-sep account names to block on push
